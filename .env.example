# ═══════════════════════════════════════════════════════════
# SyncBooks Desktop - Environment Configuration
# ═══════════════════════════════════════════════════════════

# Local JWT secret (auto-generated on first run if not set)
LOCAL_JWT_SECRET=your-local-secret-key-here

# ── Cloud Sync Configuration ──
# These are configured via the Settings UI, but can also be set here.
# The desktop app authenticates with user's email/password against the cloud.
CLOUD_API_URL=https://syncbooksapp.com
# CLOUD_API_URL=http://localhost:5000  # For local development

# Desktop sync secret (must match backend's DESKTOP_SYNC_SECRET)
# Used for server-to-server sync when user token isn't available
DESKTOP_SYNC_SECRET=a4f2e8d1c9b6f3a7e5d2c8b4f1a9e6d3c7b5f2a8e4d1c9b6f3a7e5d2c8b4f1a9

# ── Development ──
NODE_ENV=development
